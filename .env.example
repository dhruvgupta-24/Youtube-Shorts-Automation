# ─────────────────────────────────────────────────────────────────────────────
# YouTube Shorts Automation — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# ── Google Gemini (used for clip scoring & title/hook generation) ─────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI (alternative to Gemini) ───────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── AI Provider selection ─────────────────────────────────────────────────────
# Set to "gemini" or "openai"
AI_PROVIDER=gemini

# ── Whisper (local transcription, strategy 2) ─────────────────────────────────
# Options: tiny, base, small, medium, large
WHISPER_MODEL=tiny

# ── File paths ────────────────────────────────────────────────────────────────
# Directory for temporary files, logs, and state
TMP_DIR=C:/tmp

# Path to processed-videos state file (defaults to TMP_DIR/processed_videos.json)
# PROCESSED_FILE=C:/tmp/processed_videos.json

# Path to FFmpeg bin directory (added to PATH at startup)
# Leave blank if ffmpeg is already on your system PATH
FFMPEG_BIN=C:/ffmpeg/bin

# ── Timeouts (seconds) ────────────────────────────────────────────────────────
WHISPER_TIMEOUT=1800
DOWNLOAD_TIMEOUT=900
SECTION_TIMEOUT=600
AI_TIMEOUT=20

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to "true" to disable all external AI API calls (local scoring only)
LOCAL_ONLY=false
