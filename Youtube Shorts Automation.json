    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const fs = require('fs');\nconst it = $input.item.json;\nif (it.skip === true) return { json: it };\nconst { videoId='', channelId='', videoTitle='', channelTitle='' } = it;\nif (!videoId) return { json: { skip: true, reason: 'No videoId', videoId:'', channelId, videoTitle, channelTitle } };\nlet processed = {};\ntry {\n  if (fs.existsSync('C:/tmp/processed_videos.json')) {\n    const raw = fs.readFileSync('C:/tmp/processed_videos.json','utf8').trim();\n    if (raw) processed = JSON.parse(raw);\n  }\n} catch(e) {}\nconst entry = processed[channelId];\n// ONLY skip when fully completed — never block on 'uploading'\nif (entry && entry.videoId === videoId && entry.status === 'completed') {\n  return { json: { skip: true, reason: 'Already fully completed', videoId, channelId, videoTitle, channelTitle } };\n}\nconst uploadedTimestamps = (entry && entry.videoId === videoId && Array.isArray(entry.clips))\n  ? entry.clips.map(c => ({ start: c.start, end: c.end, clipIndex: c.clipIndex }))\n  : [];\nreturn { json: { skip: false, videoId, channelId, videoTitle, channelTitle, uploadedTimestamps } };"
      },
