    {
      "parameters": {
        "jsCode": "const fs   = require('fs');\nconst path = require('path');\n// items[0] is the Mark Upload Started response.\n// The server now echoes back clipPath + all metadata in its response,\n// so we can safely use items[0].json for everything.\nconst d = items[0].json;\nconst clipPath = d.clipPath;\nif (!clipPath) throw new Error('clipPath missing from Mark Upload Started response. Got: ' + JSON.stringify(d));\nif (!fs.existsSync(clipPath)) throw new Error('Clip file not found on disk: ' + clipPath);\nconst buf = fs.readFileSync(clipPath);\nreturn [{\n  json: { ...d },\n  binary: {\n    data: {\n      data:     buf.toString('base64'),\n      mimeType: 'video/mp4',\n      fileName: path.basename(clipPath)\n    }\n  }\n}];"
      },
