    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const data = $input.item.json;\nif (!data.items || data.items.length === 0) return { json: { skip: true, reason: 'No items', videoId: '', channelId: '', videoTitle: '', channelTitle: '' } };\nfor (const item of data.items) {\n  const snippet = item.snippet || {};\n  const details = item.contentDetails || {};\n  const title = snippet.title || '';\n  const m = (details.duration || '').match(/PT(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?/);\n  const total = parseInt(m?.[1]||0)*3600 + parseInt(m?.[2]||0)*60 + parseInt(m?.[3]||0);\n  if (total > 0 && total < 121) continue;\n  if (title.toLowerCase().includes('#short')) continue;\n  if (total < 480) continue;\n  return { json: { skip: false, videoId: item.id, channelId: snippet.channelId||'', videoTitle: title, channelTitle: snippet.channelTitle||'', totalSeconds: total } };\n}\nreturn { json: { skip: true, reason: 'No suitable video', videoId: '', channelId: data.items[0]?.snippet?.channelId||'', videoTitle: '', channelTitle: '' } };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -544,
        -336
