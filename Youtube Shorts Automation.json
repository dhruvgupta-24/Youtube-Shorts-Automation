    {
      "parameters": {
        "jsCode": "const d = items[0].json;\nconst base = {\n  videoId: d.videoId||'', videoTitle: d.videoTitle||'',\n  channelId: d.channelId||'', channelTitle: d.channelTitle||'',\n  strategy: typeof d.strategy==='number' ? d.strategy : 1,\n  videoPath: d.videoPath||null, detectedLanguage: d.detectedLanguage||'en'\n};\nif (!d.success || !Array.isArray(d.clips) || d.clips.length === 0) {\n  return [{ json: { ...base, success:false, error:d.error||'No clips',\n    start:'00:00', end:'01:00', title:'', shortTitle:'', description:'',\n    clipIndex:1, score:0, totalClips:1 } }];\n}\nconst totalClips = d.clips.length;\n// Each item carries ALL its own data — no downstream node needs to\n// reference back to this node via $('Split Clips').item\nreturn d.clips.map((c, i) => ({\n  json: {\n    success: true,\n    videoId:          c.videoId      || base.videoId,\n    videoTitle:       c.videoTitle   || base.videoTitle,\n    channelId:        c.channelId    || base.channelId,\n    channelTitle:     c.channelTitle || base.channelTitle,\n    strategy:         base.strategy,\n    videoPath:        c.videoPath    || base.videoPath || null,\n    detectedLanguage: c.detectedLanguage || base.detectedLanguage,\n    clipPath:         null,\n    start:            c.start   || '00:00',\n    end:              c.end     || '01:00',\n    title:            c.title   || ('Clip ' + (i+1)),\n    shortTitle:       c.shortTitle  || ((c.videoTitle||base.videoTitle) + ' #Shorts'),\n    description:      c.description || '#Shorts #YouTubeShorts',\n    clipIndex:        c.clipIndex   || (i+1),\n    score:            typeof c.score==='number' ? c.score : 0,\n    totalClips\n  }\n}));"
      },
