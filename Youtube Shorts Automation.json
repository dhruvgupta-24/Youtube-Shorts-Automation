        "jsCode": "const d = items[0].json;\n// items[0] here is the YouTube upload response merged with our clip data\n// that was passed through Read Clip Binary → Upload to YouTube\nconst clipIndex  = d.clipIndex  || 1;\nconst totalClips = d.totalClips || 1;\nconst status = (clipIndex >= totalClips) ? 'completed' : 'uploading';\nconst pathsToDelete = (status === 'completed')\n  ? [d.clipPath, d.videoPath].filter(Boolean)\n  : [d.clipPath].filter(Boolean);\nreturn [{ json: {\n  videoId:      d.videoId      || '',\n  videoTitle:   d.videoTitle   || '',\n  channelId:    d.channelId    || '',\n  channelTitle: d.channelTitle || '',\n  clipIndex, totalClips,\n  start: d.start || '', end: d.end || '',\n  status, pathsToDelete\n} }];"
